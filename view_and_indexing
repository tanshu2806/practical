-- ============================================================
-- SECTION C: INDEXING
-- ============================================================

-- Index on Student Email (frequently searched)
CREATE INDEX idx_student_email
ON Student(Email);

-- Index on Student Name
CREATE INDEX idx_student_name
ON Student(Name);

-- Index on Course Name
CREATE INDEX idx_course_name
ON Course(CourseName);

-- Composite index on Enrollment (StudentID + CourseID)
CREATE INDEX idx_enrollment_student_course
ON Enrollment(StudentID, CourseID);

-- Index on EnrollmentDate for date range queries
CREATE INDEX idx_enrollment_date
ON Enrollment(EnrollmentDate);

-- ============================================================
-- MEASURE QUERY PERFORMANCE
