    {
        $group: {
            _id: "$user",
            totalPosts:  { $sum: 1 },
            totalLikes:  { $sum: "$likes" },
            totalShares: { $sum: "$shares" },
            avgLikes:    { $avg: "$likes" }
        }
    },
    { $sort: { totalLikes: -1 } }
])

// ============================================================
