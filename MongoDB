// ============================================================
// SECTION E: AGGREGATION PIPELINE
// ============================================================

// 1. Total sales amount
db.sales.aggregate([
    { $group: { _id: null, totalSales: { $sum: "$amount" } } }
])

// 2. Total sales per category
db.sales.aggregate([
    {
        $group: {
            _id: "$category",
            totalRevenue: { $sum: "$amount" },
            totalItems:   { $sum: "$qty" },
            avgAmount:    { $avg: "$amount" }
        }
    },
    { $sort: { totalRevenue: -1 } }
])

// 3. Total sales per product
db.sales.aggregate([
    {
        $group: {
            _id: "$product",
            totalRevenue: { $sum: { $multiply: ["$amount", "$qty"] } },
            totalQtySold: { $sum: "$qty" }
        }
    },
    { $sort: { totalRevenue: -1 } }
])

// 4. Filter + group: Electronics only, total revenue
db.sales.aggregate([
    { $match: { category: "Electronics" } },
    { $group: { _id: "$product", revenue: { $sum: "$amount" } } },
    { $sort: { revenue: -1 } }
])

// 5. Average age of users per city
db.users.aggregate([
    { $group: { _id: "$city", avgAge: { $avg: "$age" }, count: { $sum: 1 } } },
    { $sort: { avgAge: -1 } }
])

// 6. Project (reshape output)
db.sales.aggregate([
    { $project: { product: 1, total: { $multiply: ["$amount", "$qty"] }, _id: 0 } },
    { $sort: { total: -1 } }
])

// 7. Lookup (JOIN equivalent — join users to sales)
db.sales.aggregate([
    {
        $lookup: {
            from: "users",
            localField: "customerEmail",
            foreignField: "email",
            as: "customerDetails"
        }
    },
    { $project: { product: 1, amount: 1, "customerDetails.name": 1, "customerDetails.city": 1 } }
])

// ============================================================
// SECTION F: INDEXING IN MONGODB
// ============================================================

// Create single field index (ascending)
db.users.createIndex({ email: 1 })

// Unique index (like UNIQUE constraint in SQL)
db.users.createIndex({ email: 1 }, { unique: true })

// Compound index (multiple fields)
db.users.createIndex({ city: 1, age: -1 })

// Text index (for full-text search)
db.users.createIndex({ name: "text", interests: "text" })

// TTL index (auto-expire documents after X seconds)
db.users.createIndex({ createdAt: 1 }, { expireAfterSeconds: 86400 })

// List all indexes on a collection
db.users.getIndexes()

// Explain query (check if index is used)
db.users.find({ email: "rahul@gmail.com" }).explain("executionStats")

// Drop an index
db.users.dropIndex({ email: 1 })


