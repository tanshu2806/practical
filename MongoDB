// ============================================================
// QUERY 1: Find top trending hashtags
// (Unwind hashtag arrays, group and count, sort by frequency)
// ============================================================
db.posts.aggregate([
    { $unwind: "$hashtags" },
    {
        $group: {
            _id: "$hashtags",
            postCount: { $sum: 1 },
            totalLikes: { $sum: "$likes" }
        }
    },
    { $sort: { postCount: -1, totalLikes: -1 } },
    { $limit: 10 },
    { $project: { hashtag: "$_id", postCount: 1, totalLikes: 1, _id: 0 } }
])

// ============================================================
// QUERY 2: Most engaging posts (by likes + shares)
// ============================================================
db.posts.aggregate([
    {
        $addFields: {
            engagementScore: { $add: ["$likes", "$shares", "$comments"] }
        }
    },
    { $sort: { engagementScore: -1 } },
    { $limit: 5 },
    { $project: { user: 1, hashtags: 1, likes: 1, shares: 1, comments: 1, engagementScore: 1 } }
])

