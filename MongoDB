    {
        $group: {
            _id: { $dateToString: { format: "%Y-%m-%d", date: "$timestamp" } },
            postsCount:  { $sum: 1 },
            totalLikes:  { $sum: "$likes" }
        }
    },
    { $sort: { "_id": 1 } }
])

