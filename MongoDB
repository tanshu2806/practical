// ============================================================
// SECTION B: READ (Query documents)
// ============================================================

// Find all users
db.users.find()

// Pretty print
db.users.find().pretty()

// Find with filter
db.users.find({ city: "Pune" })

// Find one document
db.users.findOne({ email: "rahul@gmail.com" })

// Comparison operators
db.users.find({ age: { $gt: 25 } })           // age > 25
db.users.find({ age: { $gte: 25 } })          // age >= 25
db.users.find({ age: { $lt: 30 } })           // age < 30
db.users.find({ age: { $between: [22, 30] } })// NOT valid — use $gte + $lte:
db.users.find({ age: { $gte: 22, $lte: 30 } })

// Logical operators
db.users.find({ $or: [ { city: "Pune" }, { city: "Mumbai" } ] })
db.users.find({ $and: [ { age: { $gt: 20 } }, { city: "Pune" } ] })

// Array query (find users with a specific interest)
db.users.find({ interests: "music" })
db.users.find({ interests: { $in: ["gaming", "sports"] } })

// Projection (select specific fields)
db.users.find({}, { name: 1, email: 1, _id: 0 })

// Sort, limit, skip
db.users.find().sort({ age: 1 })        // ascending
db.users.find().sort({ age: -1 })       // descending
db.users.find().limit(3)
db.users.find().skip(2).limit(2)        // pagination

// Count documents
db.users.countDocuments({ city: "Pune" })

// ============================================================
// SECTION C: UPDATE
// ============================================================

// Update one document
db.users.updateOne(
    { email: "rahul@gmail.com" },
    { $set: { age: 26 } }
)

// Update multiple documents
db.users.updateMany(
    { city: "Pune" },
    { $set: { region: "West" } }
)

// Increment a field
db.users.updateOne(
    { email: "rahul@gmail.com" },
    { $inc: { age: 1 } }
)

// Add to an array
db.users.updateOne(
    { email: "priya@gmail.com" },
    { $push: { interests: "travel" } }
)

// Remove from an array
db.users.updateOne(
    { email: "priya@gmail.com" },
    { $pull: { interests: "cooking" } }
)

// Upsert (insert if not found)
db.users.updateOne(
    { email: "new@gmail.com" },
    { $set: { name: "New User", age: 20, city: "Kolkata" } },
    { upsert: true }
)

// ============================================================
// SECTION D: DELETE
// ============================================================

// Delete one document
db.users.deleteOne({ email: "new@gmail.com" })

// Delete multiple documents
db.users.deleteMany({ city: "Delhi" })

